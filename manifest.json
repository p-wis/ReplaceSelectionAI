{
  "manifest_version": 2,
  "name": "ReplaceSelectionAI",
  "version": "1.1.0",
  "description": "Select text in any editable field, process it with AI (OpenAI, Claude, or any OpenAI-compatible provider), and replace it with the result. Define your own prompts via the extension popup.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "webNavigation",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "replaceselectionai@extension",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "ReplaceSelectionAI",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  }
}
